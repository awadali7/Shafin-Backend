# Server Configuration
NODE_ENV=development
PORT=5001

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/elearning_db
DB_POOL_MAX=10
DB_POOL_MIN=2

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-here-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Email Configuration
# For Gmail, use App Password: https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Backend/API URL (for generating image URLs and links)
# In production, set this to your API domain (e.g., https://api.diagtools.in)
BACKEND_URL=http://localhost:5001

# Public URL (for public assets like PDFs, images)
# This is used for generating URLs to uploaded files that are publicly accessible
# If not set, will use FRONTEND_URL, then BACKEND_URL
# In production, set to your public domain (e.g., https://www.diagtools.in)
# PUBLIC_URL=https://www.diagtools.in

# Admin Configuration (for initial admin creation)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=secure-password-here

# VAPID Keys for Push Notifications
# Generate using: node src/utils/generateVapidKeys.js
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@yourdomain.com

# Razorpay Payment Gateway Configuration
# Get your keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Optional: For webhook signature verification
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

